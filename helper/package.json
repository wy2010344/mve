{
  "name": "mve-helper",
  "version": "4.0.2",
  "description": "Helper utilities for MVE framework",
  "keywords": [
    "mve",
    "helper",
    "utilities",
    "reactive"
  ],
  "author": "wy2010344",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "typings": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wy2010344/mve.git"
  },
  "homepage": "https://github.com/wy2010344/mve#readme",
  "bugs": {
    "url": "https://github.com/wy2010344/mve/issues"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint src/ --fix",
    "lint:check": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "lint-staged": "catalog:",
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "mve-core": "workspace:*",
    "wy-helper": "workspace:*"
  }
}